<Window x:Class="Revive.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revive" Height="420" Width="700"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="Black">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0D0D0D" BorderBrush="#222222" BorderThickness="0,0,1,0">
            <StackPanel Margin="12,24,12,0">
                <TextBlock Text="REVIVE" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,28"/>
                <Button Content="Home" Height="40" Margin="0,0,0,10" Click="Home_Click"/>
                <Button Content="Settings" Height="40" Click="Settings_Click"/>
            </StackPanel>
        </Border>

        <Frame Grid.Column="1" x:Name="ContentFrame" NavigationUIVisibility="Hidden" Background="Black"/>
    </Grid>
</Window>
