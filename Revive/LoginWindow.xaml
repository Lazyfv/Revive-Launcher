<Window x:Class="Revive.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revive" Height="460" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="Black">
    <Grid Margin="44">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="REVIVE" FontSize="44" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,36"/>

        <Label Grid.Row="1" Content="Email" FontSize="14"/>
        <TextBox Grid.Row="2" x:Name="EmailBox" Height="40" FontSize="14" Margin="0,6,0,20"/>

        <Label Grid.Row="3" Content="Password" FontSize="14"/>
        <PasswordBox Grid.Row="4" x:Name="PasswordBox" Height="40" FontSize="14" Margin="0,6,0,28"/>

        <Button Grid.Row="5" Content="Login" Height="46" FontSize="15" Click="Login_Click"/>
    </Grid>
</Window>
