<Page x:Class="Revive.Pages.Settings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Black">
    <Grid Margin="40,50,40,0" VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Fortnite Path"/>

        <Grid Grid.Row="1" Margin="0,4,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="PathBox" Height="32" TextChanged="PathBox_TextChanged"/>
            <Button Grid.Column="1" Content="..." Width="40" Height="32" Margin="8,0,0,0" Click="Browse_Click"/>
        </Grid>

        <Button Grid.Row="2" Content="Save" Width="100" Height="36" HorizontalAlignment="Right" Click="Save_Click"/>
    </Grid>
</Page>
